# n8n-workflows-portfolio — variables d'environnement
#
# Ce fichier liste TOUTES les variables/credentials nécessaires pour redéployer
# un ou plusieurs des workflows de ce portfolio. Chaque README.md de workflow
# précise le sous-ensemble qui le concerne réellement — inutile de tout
# configurer pour tester un seul workflow.
#
# Note n8n : les clés API des services externes sont normalement gérées via
# le système de "Credentials" natif de n8n (chiffré, séparé du JSON du
# workflow), pas via des variables d'environnement classiques. Les entrées
# ci-dessous servent de checklist de ce qu'il faut créer comme credential
# n8n, ou comme variable d'environnement pour les valeurs en dur (IDs de
# feuilles, dossiers, webhooks, etc.).

# ---------------------------------------------------------------------------
# IA / LLM
# ---------------------------------------------------------------------------
YOUR_ANTHROPIC_API_KEY=            # Credential n8n "Anthropic API" (Claude)
YOUR_OPENAI_API_KEY=               # Credential n8n "OpenAI API" (Whisper, embeddings, GPT)
YOUR_DEEPSEEK_API_KEY=             # Credential n8n "DeepSeek API" (tri Gmail, classification)
YOUR_TAVILY_API_KEY=               # Recherche web (agent IA veille/audit digital)
YOUR_NOVA_SONIC_ENDPOINT=          # Endpoint voix temps réel (Nova Sonic)

# ---------------------------------------------------------------------------
# CRM / Ventes
# ---------------------------------------------------------------------------
YOUR_HUBSPOT_TOKEN=                # Credential n8n "HubSpot API" (deals, contacts, pipelines)
YOUR_EVOLIZ_PUBLIC_KEY=            # Facturation Evoliz
YOUR_EVOLIZ_SECRET_KEY=
YOUR_DEAL_ID_HUBSPOT=              # Exemple d'ID de deal (à adapter)

# ---------------------------------------------------------------------------
# Messagerie / Chatbots
# ---------------------------------------------------------------------------
YOUR_WHATSAPP_PHONE_NUMBER_ID=     # Meta WhatsApp Cloud API
YOUR_META_PAGE_ACCESS_TOKEN=       # Messenger / Meta Graph API
YOUR_MESSENGER_VERIFY_TOKEN=
YOUR_WEBHOOK_VERIFY_TOKEN=
YOUR_TELEGRAM_BOT_TOKEN=           # Credential n8n "Telegram API"
YOUR_TELEGRAM_CHAT_ID=
YOUR_CHATWOOT_API_TOKEN=

# ---------------------------------------------------------------------------
# Téléphonie
# ---------------------------------------------------------------------------
YOUR_TWILIO_ACCOUNT_SID=
YOUR_TWILIO_AUTH_TOKEN=
YOUR_FREEPBX_HOST=
YOUR_AMI_USERNAME=                 # Asterisk Manager Interface (click-to-call)
YOUR_AMI_PASSWORD=

# ---------------------------------------------------------------------------
# Google Workspace (Sheets / Drive / Calendar / Gmail)
# ---------------------------------------------------------------------------
YOUR_GOOGLE_OAUTH_CLIENT_ID=       # Credential n8n OAuth2 Google (Sheets/Drive/Calendar/Gmail)
YOUR_GOOGLE_OAUTH_CLIENT_SECRET=
YOUR_GOOGLE_SHEET_ID=              # ID générique de feuille CRM/leads (voir README par workflow)
YOUR_GOOGLE_SHEET_ID_TRI_MEA=
YOUR_GOOGLE_SHEET_ID_VIDEOS_YOUTUBE=
YOUR_GOOGLE_DRIVE_FOLDER_ID=       # ID générique de dossier (voir README par workflow)
YOUR_GOOGLE_DRIVE_BACKUP_FOLDER_ID=
YOUR_GOOGLE_CALENDAR_ID=
YOUR_GOOGLE_ALERTS_ID=
YOUR_YOUTUBE_PLAYLIST_ID_IA_SEO=
YOUR_YOUTUBE_PLAYLIST_ID_VEILLE=

# ---------------------------------------------------------------------------
# Google Ads / SEO
# ---------------------------------------------------------------------------
YOUR_GOOGLE_ADS_CUSTOMER_ID=
YOUR_GOOGLE_ADS_DEVELOPER_TOKEN=
YOUR_RECAPTCHA_SITE_KEY=

# ---------------------------------------------------------------------------
# Infra / Back-up / Sécurité
# ---------------------------------------------------------------------------
YOUR_OVH_APPLICATION_KEY=          # API OVH (gestion DNS)
YOUR_OVH_APPLICATION_SECRET=
YOUR_OVH_CONSUMER_KEY=
YOUR_SERVER_IP=                    # VPS / serveur de prod
YOUR_DB_PASSWORD=                  # PostgreSQL
YOUR_SSH_PRIVATE_KEY=              # Credential n8n SSH (déploiements, back-ups VPS)

# ---------------------------------------------------------------------------
# Autres intégrations métier
# ---------------------------------------------------------------------------
YOUR_ANTSROUTE_API_KEY=            # Planification tournées terrain (ANTs Route)
YOUR_SIGNATUREAPI_KEY=             # DocuSeal / signature électronique de devis
YOUR_CLICKUP_TEAM_ID=
YOUR_CLICKUP_SPACE_ID=
YOUR_CLICKUP_LIST_ID=
YOUR_CLICKUP_ASSIGNEE_ID=

# ---------------------------------------------------------------------------
# Divers (identifiants d'exemple, à adapter par workflow)
# ---------------------------------------------------------------------------
YOUR_WEBHOOK_ID=
YOUR_WEBHOOK_PATH=
YOUR_ADRESSE_DOMICILE=             # Point de départ tournée (optimisation trajets)
YOUR_TECH1_HOME_COORDS=
YOUR_TECH2_HOME_COORDS=

    {
      "parameters": {
        "jsCode": "var msg     = $input.first().json.message;\nvar type    = 'unknown';\nvar fileId  = null;\nvar texte   = msg.text || msg.caption || '';\nvar magasinMemo = texte.trim();\n\nif (msg.photo) {\n  var photos = msg.photo;\n  fileId = photos[photos.length - 1].file_id;\n  type = 'photo';\n} else if (msg.document) {\n  var mime = msg.document.mime_type || '';\n  fileId = msg.document.file_id;\n  type = mime.includes('pdf') ? 'pdf' : 'document';\n} else if (msg.text) {\n  type = 'texte';\n}\n\nreturn [{\n  json: {\n    type:        type,\n    fileId:      fileId,\n    magasinMemo: magasinMemo,\n    chatId:      msg.chat.id,\n    messageId:   msg.message_id\n  }\n}];"
      },

    {
      "parameters": {
        "jsCode": "var raw = $input.first().json.content[0].text.trim()\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```\\s*$/i, '');\n\n\nvar parsed = JSON.parse(raw);\n\n\nvar date    = parsed.date || new Date().toLocaleDateString('fr-FR');\nvar magasin = parsed.magasin || '';\nvar articles = parsed.articles || [];\n\n// Retourne une ligne par article pour Google Sheets\nreturn articles.map(function(a) {\n  return {\n    json: {\n      magasin,\n      date,\n      categorie:    a.categorie || '',\n      nom:          a.nom || a.nom_exact || '',\n      nom_exact:    a.nom_exact || '',\n      prix_unitaire: a.prix_unitaire || '',\n      prix_kg:      a.prix_kg || '',\n      poids:        a.poids || '',\n      nb_articles:  articles.length\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1792, 192],
      "id": "f9f6ceda-f3ec-4430-ba3b-c88d77d3e5da",
      "name": "Code JS - Parse + Structure lignes"
    },
    {
      "parameters": {
        "jsCode": "var all = $input.all();\n\nvar fileInfo = null;\nvar rows = [];\n\nall.forEach(function(item) {\n  var d = item.json;\n  if (d.result && d.result.file_path) {\n    fileInfo = d.result;\n  } else if (d['Nom exact de l\\'article']) {\n    rows.push(d);\n  }\n});\n\nvar fileType  = $('Code JS - Détecte').first().json.type;\nvar mediaType = fileType === 'pdf' ? 'application/pdf' : 'image/jpeg';\nvar contentType = fileType === 'pdf' ? 'document' : 'image';\nvar base64 = $input.first().json.imageBase64;\n\nvar magasin = $('Code JS - Détecte').first().json.magasinMemo\n            || $getWorkflowStaticData('global').magasinMemo\n            || '';\n\nvar categoriesExistantes = [...new Set(\n  rows.map(function(r) { return r['Catégorie']; }).filter(Boolean)\n)];\n\nvar produitsExistants = [...new Set(\n  rows.map(function(r) { return r['Nom exact de l\\'article']; }).filter(Boolean)\n)].slice(0, 80);\n\nvar contexteMagasin = magasin ? 'Magasin : ' + magasin + '\\n' : '';\n\nvar body = {\n  model: \"claude-sonnet-4-20250514\",\n  max_tokens: 4000,\n  system:\n    'Tu es un assistant d\\'analyse de tickets de caisse et d\\'étiquettes produit. ' +\n    'Si le prix unitaire est affiché et que le poids est connu, calcule le prix au kg (prix_unitaire / poids_en_kg).\\n' +\n    'Si seul le prix au kg est affiché, calcule le prix unitaire (prix_kg × poids_en_kg).\\n' +\n    'Retourne toujours les deux champs prix_unitaire ET prix_kg quand l\\'un des deux est calculable.\\n' +\n    'Exemple : prix_unitaire=4.75, poids=500g → prix_kg=9.50\\n' +\n    'Tu extrais les données structurées et normalises les noms selon les existants. ' +\n    'Tu réponds UNIQUEMENT en JSON valide sans backticks.\\n\\n' +\n    'Catégories existantes à utiliser en priorité : ' + categoriesExistantes.join(', ') + '\\n' +\n    'Produits existants (pour uniformiser les noms) : ' + produitsExistants.join(', '),\n  messages: [{\n    role: \"user\",\n    content: [\n      {\n        type: contentType,\n        source: {\n          type: \"base64\",\n          media_type: mediaType,\n          data: base64\n        }\n      },\n      {\n        type: \"text\",\n        text: contexteMagasin +\n          'Analyse cette image et extrait TOUS les articles.\\n\\n' +\n          'Retourne ce JSON :\\n' +\n          '{\"magasin\":\"...\",\"date\":\"JJ/MM/AAAA\",\"articles\":[{\"categorie\":\"...\",\"nom\":\"...\",\"nom_exact\":\"...\",\"prix_unitaire\":null,\"prix_kg\":null,\"poids\":null}]}'\n      }\n    ]\n  }]\n};\n\nreturn [{\n  json: {\n    body: body\n  }\n}];"
      },

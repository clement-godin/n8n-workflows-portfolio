      "name": "Google Sheets - Lire leads",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [480, 160],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "rCFvQBVaQVzg9Lrq",
          "name": "CLIENT OAUTH COMPTE GOOGLE SHEET EMAFUITES"
        }
      },
      "notes": "⚠️ Configurer: remplacer SHEETS_LEADS_ID_A_CONFIGURER par l'ID réel"
    },
    {
      "parameters": {
        "jsCode": "\n// Filter only new rows since last execution using staticData\nconst staticData = $getWorkflowStaticData('global');\nconst rows = $input.all();\n\n// Track last processed timestamp\nconst lastProcessed = staticData.lastProcessedTimestamp || 0;\nconst now = Date.now();\n\n// Filter rows with timestamp newer than last processed\n// Google Sheets rows include a Date column\nconst newRows = [];\nfor (const row of rows) {\n  const dateStr = row.json['Date'] || row.json['Horodateur'] || '';\n  if (!dateStr) continue;\n  const rowTime = new Date(dateStr).getTime();\n  if (!isNaN(rowTime) && rowTime > lastProcessed) {\n    newRows.push(row);\n  }\n}\n\n// Update last processed to now\nstaticData.lastProcessedTimestamp = now;\n\nif (newRows.length === 0) return [];\nreturn newRows.map(r => ({ json: { ...r.json, source: 'Google Sheets' } }));\n"
      },
      "id": "cb451dc5-c842-4495-a89c-dbb773de1148",
      "name": "Code JS - Filtre nouvelles lignes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [704, 160],
      "notes": "Garde seulement les lignes nouvelles depuis la dernière exécution via staticData"
    },
    {
      "parameters": {
        "jsCode": "\nconst item = $input.first().json;\n\nconst prenom = (item['Prénom'] || item['prenom'] || item['Nom'] || '').toString().trim();\nconst nom = (item['Nom de famille'] || item['nom'] || '').toString().trim();\nconst phone = (item['Téléphone'] || item['telephone'] || item['Tel'] || '').toString();\nconst email = (item['Email'] || item['email'] || '').toString().trim().toLowerCase();\nconst source = (item['source'] || 'Google Sheets').toString();\nconst message = (item['Message'] || item['message'] || item['Problème'] || '').toString().trim();\nconst ville = (item['Ville'] || item['ville'] || '').toString().trim();\nconst typeFuite = (item['Type de fuite'] || item['type_fuite'] || '').toString().trim();\n\nlet tel = phone.replace(/[\\s\\-\\.\\(\\)]/g, '');\nif (tel.startsWith('0')) tel = '33' + tel.slice(1);\nif (tel && !tel.startsWith('+')) tel = '+' + tel;\n\nconst nom_complet = `${prenom} ${nom}`.trim();\n\nreturn [{ json: {\n  prenom, nom, phone: tel, email, source, message, ville, typeFuite,\n  fullName: nom_complet || prenom\n}}];\n"
      },
      "id": "beaa1d03-5fb6-46a5-89e8-0a0138f43bd1",
      "name": "Code JS - Normalise lead",

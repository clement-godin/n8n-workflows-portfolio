        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"filterGroups\": [{\"filters\": [{\"propertyName\": \"phone\", \"operator\": \"EQ\", \"value\": \"{{ $json.phone }}\"}]}, {\"filters\": [{\"propertyName\": \"email\", \"operator\": \"EQ\", \"value\": \"{{ $json.email }}\"}]}], \"properties\": [\"firstname\", \"email\", \"phone\"], \"limit\": 1}",
        "options": {}
      },

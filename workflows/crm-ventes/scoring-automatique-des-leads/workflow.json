      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst lead = $('Webhook - Scoring lead').first().json;\n\n// Extraire le texte de la réponse Claude\nconst rawText = response.content[0].text.trim();\n\nlet scoring;\ntry {\n  scoring = JSON.parse(rawText);\n} catch (e) {\n  // Fallback si JSON malformé\n  scoring = {\n    score: 5,\n    priorite: 'NORMALE',\n    raison: 'Erreur de parsing — vérification manuelle requise',\n    intervention_estimee: 'Cette semaine',\n    valeur_estimee: 'Moyenne (200-500€)'\n  };\n}\n\nreturn [{\n  json: {\n    lead_id:               lead.id,\n    lead_name:             lead.name,\n    lead_phone:            lead.phone,\n    lead_city:             lead.city,\n    lead_description:      lead.description,\n    score:                 scoring.score,\n    priorite:              scoring.priorite,\n    raison:                scoring.raison,\n    intervention_estimee:  scoring.intervention_estimee,\n    valeur_estimee:        scoring.valeur_estimee\n  }\n}];"
      },

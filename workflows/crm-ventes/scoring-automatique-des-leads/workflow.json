              "content": "=Analyse ce lead :\\nNom : {{ $json.name }}\\nVille : {{ $json.city }}\\nUrgence déclarée : {{ $json.urgency }}\\nBudget : {{ $json.budget }}\\nDescription : {{ $json.description }}"
            }

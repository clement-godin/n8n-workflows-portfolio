    {
      "parameters": {
        "jsCode": "\nconst deal = $('Code - Extraire contact').item.json;\nconst contact = $input.first().json.properties || {};\nconst prenom = contact.firstname || 'cher client';\nconst phone = contact.phone || '';\nconst email = contact.email || '';\n\nlet tel = phone.replace(/[\\s\\-\\.\\(\\)]/g, '');\nif (tel.startsWith('0')) tel = '33' + tel.slice(1);\nif (tel && !tel.startsWith('+')) tel = '+' + tel;\n\nreturn [{ json: { ...deal, prenom, phone: tel, email, hasPhone: !!phone } }];\n"
      },

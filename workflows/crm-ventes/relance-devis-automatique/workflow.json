        "nodeCredentialType": "hubspotAppToken",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"filterGroups\": [{\"filters\": [{\"propertyName\": \"dealstage\", \"operator\": \"EQ\", \"value\": \"qualifiedtobuy\"}, {\"propertyName\": \"a_relancer_manuellement\", \"operator\": \"NOT_HAS_PROPERTY\"}]}, {\"filters\": [{\"propertyName\": \"dealstage\", \"operator\": \"EQ\", \"value\": \"qualifiedtobuy\"}, {\"propertyName\": \"a_relancer_manuellement\", \"operator\": \"EQ\", \"value\": \"false\"}]}], \"properties\": [\"dealname\", \"dealstage\", \"hs_lastmodifieddate\", \"nb_relances\", \"derniere_relance\", \"a_relancer_manuellement\"], \"sorts\": [{\"propertyName\": \"hs_lastmodifieddate\", \"direction\": \"ASCENDING\"}], \"limit\": 100}",
        "options": {}
      },
      "id": "83dd2738-0003-4549-8833-0bc674d57b26",
      "name": "HubSpot - Deals devis envoyé",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [480, 352],
      "credentials": {
        "hubspotAppToken": {
          "id": "JnaOUFzIE4lA3O1R",
          "name": "HubSpot account EMA FUITES"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "\n// Filter deals needing follow-up\nconst items = $input.all();\nconst toProcess = [];\n\nfor (const item of items) {\n  const deals = item.json.results || [];\n  for (const d of deals) {\n    const props = d.properties || {};\n    const lastModified = new Date(props.hs_lastmodifieddate || props.createdate);\n    const derniereRelance = props.derniere_relance ? new Date(props.derniere_relance) : null;\n    const nbRelances = parseInt(props.nb_relances || '0');\n    const now = new Date();\n    \n    // Use derniere_relance if set, otherwise hs_lastmodifieddate\n    const referenceDate = derniereRelance || lastModified;\n    const daysSince = (now - referenceDate) / (1000 * 60 * 60 * 24);\n    \n    // J+2 (nbRelances = 0): need 2+ days since last modification, no relance yet\n    // J+5 (nbRelances = 1): need 3+ more days since first relance (total ~5 days)\n    // J+10 (nbRelances = 2): need 5+ more days since second relance (total ~10 days)\n    \n    let shouldRelance = false;\n    if (nbRelances === 0 && daysSince >= 2) shouldRelance = true;\n    else if (nbRelances === 1 && daysSince >= 3) shouldRelance = true;\n    else if (nbRelances === 2 && daysSince >= 5) shouldRelance = true;\n    \n    if (shouldRelance) {\n      toProcess.push({ json: {\n        dealId: d.id,\n        dealName: props.dealname || '',\n        nbRelances: nbRelances\n      }});\n    }\n  }\n}\n\nif (toProcess.length === 0) return [];\nreturn toProcess;\n"
      },

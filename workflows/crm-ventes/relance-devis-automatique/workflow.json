      "parameters": {
        "jsCode": "\n// Merge deal info with contact info\nconst deal = $('Code JS - Filtre deals à relancer').item.json;\nconst associations = $input.first().json;\nconst contactIds = associations?.results || [];\n\nif (contactIds.length === 0) {\n  return [{ json: { ...deal, hasContact: false } }];\n}\n\nreturn [{ json: { ...deal, contactId: contactIds[0].id, hasContact: true } }];\n"
      },

      "parameters": {
        "jsCode": "var all = $input.all();\nvar corpus = '';\n\nvar stripHtml = function(str) {\n  return (str || '').replace(/<[^>]+>/g, '').replace(/&amp;/g, '&').replace(/&#39;/g, \"'\").replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '\"');\n};\n\nall.forEach(function(item) {\n  var d = item.json;\n  if (d.results && d.query) {\n    d.results.slice(0, 5).forEach(function(r) {  // 5 par requête Tavily\n      corpus += 'Tavily | ' + stripHtml(r.title) + ' — ' + stripHtml(r.content).slice(0, 500) + '\\n';\n    });\n  }\n  if (d.title && (d.link || d.guid)) {\n    corpus += 'RSS | ' + stripHtml(d.title) + ' — ' + stripHtml(d.contentSnippet || d.content || d.summary || '').slice(0, 700) + '\\n';\n  }\n});\n\nreturn [{\n  json: {\n    corpus: corpus,\n    date: new Date().toLocaleDateString('fr-FR')\n  }\n}];"
      },

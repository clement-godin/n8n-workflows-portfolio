    {
      "parameters": {
        "jsCode": "var raw = $input.first().json.choices[0].message.content.trim();\nvar ids = $input.first().json.ids;\n\nvar digest;\ntry {\n  digest = JSON.parse(raw);\n} catch(e) {\n  return [{ json: { message: '⚠️ Erreur de parsing du digest.', ids: [] } }];\n}\n\nvar date = new Date().toLocaleDateString('fr-FR');\nvar messages = [];\n\nvar header =\n  '🔭 <b>Veille Stratégique</b>\\n' +\n  '📅 Semaine du ' + date + '\\n' +\n  '─────────────────\\n\\n' +\n  '⭐ <b>À retenir</b>\\n' +\n  digest.a_retenir + '\\n\\n' +\n  '📈 <b>Tendance</b>\\n' +\n  digest.tendance + '\\n';\n\nvar current = header;\n\nfor (var i = 0; i < digest.themes.length; i++) {\n  var theme = digest.themes[i];\n  var themeBlock = \n    '\\n─────────────────\\n' +\n    theme.emoji + ' <b>' + theme.nom.toUpperCase() + '</b>\\n\\n';\n\n  for (var j = 0; j < theme.points.length; j++) {\n    var point = theme.points[j];\n    var tag = point.actionnable ? ' 🎯' : '';\n    themeBlock += \n      '• <b>' + point.titre + '</b>' + tag + '\\n' +\n      point.detail + '\\n' +\n      '<i>— ' + point.source + '</i>\\n\\n';\n  }\n\n  if ((current + themeBlock).length > 4000) {\n    messages.push(current);\n    current = theme.emoji + ' <b>' + theme.nom.toUpperCase() + '</b> (suite)\\n\\n';\n    current += themeBlock.replace('\\n─────────────────\\n' + theme.emoji + ' <b>' + theme.nom.toUpperCase() + '</b>\\n\\n', '');\n  } else {\n    current += themeBlock;\n  }\n}\n\ncurrent += '─────────────────\\n🤖 <i>Généré par DeepSeek V4-Flash</i>';\n\nif (current.length > 0) messages.push(current);\n\nreturn messages.map(function(msg) {\n  return { json: { message: msg } };\n});"
      },

    {
      "parameters": {
        "jsCode": "var corpus = $input.first().json.corpus;\nvar date   = $input.first().json.date;\n\nvar body = {\n  model: \"deepseek-v4-flash\",\n  temperature: 0.3,\n  messages: [\n    {\n      role: \"system\",\n      content: \"Tu es un assistant de veille stratégique. Tu analyses des articles et actualités de la semaine et produis une synthèse structurée par thème. Tu gardes uniquement ce qui est vraiment important, nouveau ou actionnable. Tu ignores le contenu promotionnel ou redondant. Tu réponds UNIQUEMENT en JSON valide sans backticks.\"\n    },\n    {\n      role: \"user\",\n        \"content\": \"Voici les actualités de la semaine du \" + date + \" :\\n\\n\" + corpus +  \"\\n\\nAnalyse et réponds avec ce JSON :\\n{\\\"themes\\\":[{\\\"nom\\\":\\\"Nom du thème\\\",\\\"emoji\\\":\\\"emoji\\\",\\\"points\\\":[{\\\"titre\\\":\\\"titre court\\\",\\\"detail\\\":\\\"2-3 phrases\\\",\\\"source\\\":\\\"source\\\",\\\"actionnable\\\":true}]}],\\\"a_retenir\\\":\\\"insight le plus important de la semaine en 1 phrase\\\",\\\"tendance\\\":\\\"une tendance de fond observée cette semaine en 1 phrase\\\"}\\n\\nRègles :\\n- Crée obligatoirement un thème 'Local Hauts-de-France' avec les actualités RSS locales\\n- Crée obligatoirement un thème 'IA & Outils' avec Claude, Anthropic, DeepSeek, n8n\\n- Pour les autres thèmes, garde uniquement ce qui est important ou actionnable\\n- Ignore le contenu purement sportif ou anecdotique sauf s'il concerne directement la région\"\n    }\n  ]\n};\n\nreturn [{ json: { body: body } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        128
      ],
      "id": "4eeb85ce-b78f-4eb5-b3a9-0a42e5c82773",

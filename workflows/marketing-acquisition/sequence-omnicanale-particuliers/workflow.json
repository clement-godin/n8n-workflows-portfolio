      "parameters": {
        "jsCode": "// Délais cumulés en jours depuis le début : J0, J+2, J+5, J+10, J+20\nconst contact = $('Code JS - Filtrer contacts particuliers').item.json;\nconst etape = contact.etape;\nconst delays = [0, 2, 5, 10, 20];\n\nconst nextEtape = etape + 1;\nconst nextDelay = nextEtape < delays.length ? delays[nextEtape] - delays[etape] : null;\nconst nextDate = nextDelay !== null ? new Date(Date.now() + nextDelay * 24 * 3600 * 1000).toISOString() : null;\n\nreturn [{ json: {\n  contactId: contact.contactId,\n  newEtape: nextEtape,\n  nextDate: nextDate,\n  isLastStep: nextEtape >= 5\n}}];"
      },

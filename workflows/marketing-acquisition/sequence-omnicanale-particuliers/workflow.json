      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst contacts = result.results || [];\nconst now = new Date();\nconst toProcess = [];\n\nfor (const c of contacts) {\n  const props = c.properties || {};\n  const etape = parseInt(props.sequence_particulier_etape || '0');\n  const nextDate = props.sequence_particulier_date_debut ? new Date(props.sequence_particulier_date_debut) : null;\n\n  if (nextDate && nextDate <= now && etape < 5) {\n    toProcess.push({ json: {\n      contactId: c.id,\n      email: props.email || '',\n      phone: props.phone || '',\n      prenom: props.firstname || 'Madame/Monsieur',\n      nom: props.lastname || '',\n      etape: etape\n    }});\n  }\n}\n\nif (toProcess.length === 0) return [];\nreturn toProcess;"
      },

    {
      "parameters": {
        "jsCode": "const review = $('Code JS - Filtre nouveaux avis').first().json;\nconst claudeResponse = $input.first().json.content[0].text;\n\nconst stars = '⭐'.repeat(review.ratingNumber) + \n              '☆'.repeat(5 - review.ratingNumber);\n\nconst emoji = review.ratingNumber >= 4 ? '🟢' : \n              review.ratingNumber >= 3 ? '🟡' : '🔴';\n\nconst message = \n`${emoji} <b>Nouvel avis Google — ${review.date}</b>\n\n${stars} <b>${review.reviewer}</b>\n💬 ${review.comment}\n\n<b>Réponse suggérée par Claude :</b>\n<i>${claudeResponse}</i>\n\n👉 Valider et publier : https://business.google.com`;\n\nreturn [{ json: { message, claudeResponse, review } }];"

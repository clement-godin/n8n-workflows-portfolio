    {
      "parameters": {
        "jsCode": "const reviews = $input.first().json.reviews || [];\n\n// Récupère le timestamp de la dernière vérification\n// Stocké dans une variable n8n statique\nconst lastCheck = $getWorkflowStaticData('global').lastCheck || 0;\nconst now = Date.now();\n\n// Filtre les avis postés depuis la dernière vérification\nconst newReviews = reviews.filter(r => {\n  const reviewDate = new Date(r.updateTime).getTime();\n  return reviewDate > lastCheck;\n});\n\n// Met à jour le timestamp\n$getWorkflowStaticData('global').lastCheck = now;\n\nif (newReviews.length === 0) {\n  return [{ json: { hasNewReviews: false } }];\n}\n\nreturn newReviews.map(r => ({\n  json: {\n    hasNewReviews:  true,\n    reviewId:       r.reviewId,\n    reviewer:       r.reviewer.displayName,\n    rating:         r.starRating, // ONE TWO THREE FOUR FIVE\n    comment:        r.comment || '(sans commentaire)',\n    date:           new Date(r.updateTime).toLocaleDateString('fr-FR'),\n    ratingNumber:   { ONE:1, TWO:2, THREE:3, FOUR:4, FIVE:5 }[r.starRating]\n  }\n}));"
      },

      "id": "429814c6-554c-4d13-9be3-419af9b0badb",
      "name": "Claude - Setter Analyse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [704, 304],
      "credentials": {
        "anthropicApi": {
          "id": "8Wcb8jgMTJM6CQjM",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst orig = $('Code - Préparer Setter').item.json;\nlet parsed;\ntry { parsed = JSON.parse(resp.content[0].text); }\ncatch(e) { parsed = {intention: 'ERREUR', 'ton_détecté': '', 'réponse_suggérée': '', action_suivante: 'NURTURING_30J', note_crm: 'Erreur parsing'}; }\nreturn [{json: {\n  ...orig,\n  intention: parsed.intention,\n  ton: parsed['ton_détecté'],\n  reponse: parsed['réponse_suggérée'],\n  action: parsed.action_suivante,\n  note_crm: parsed.note_crm\n}}];"
      },

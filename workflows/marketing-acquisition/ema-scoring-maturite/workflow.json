      "parameters": {
        "jsCode": "const rowId = $('Code - Préparer Lecture').item.json.row_id;\nconst items = $input.all();\nconst found = items.find(i => i.json.ID == rowId);\nif (!found) return [{json: {ID: rowId, error: 'prospect non trouvé'}}];\nreturn [{json: found.json}];"
      },

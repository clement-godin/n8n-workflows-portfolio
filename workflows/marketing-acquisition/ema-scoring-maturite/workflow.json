      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst orig = $('Code - Préparer Scoring').item.json;\nlet parsed;\ntry { parsed = JSON.parse(resp.content[0].text); }\ncatch(e) { parsed = {score: 0, 'priorité': 'BASSE', justification: 'Erreur parsing'}; }\nreturn [{json: {...orig, score_result: parsed.score || parsed.score, priorite_result: parsed['priorité'] || parsed.priorite, justif_result: parsed.justification}}];"
      },

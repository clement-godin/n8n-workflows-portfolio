      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst checks = [\n  // DESKTOP\n  { name: \"SCORE GLOBAL DESKTOP\", value: item[\"SCORE GLOBAL DESKTOP\"], operator: \"less\", threshold: 90, unit: \"/100\" },\n  { name: \"SCORE FCP DESKTOP\", value: item[\"SCORE FCP DESKTOP\"], operator: \"greater\", threshold: 1, unit: \"s\" },\n  { name: \"SCORE LCP DESKTOP\", value: item[\"SCORE LCP DESKTOP\"], operator: \"greater\", threshold: 2, unit: \"s\" },\n  { name: \"TBT DESKTOP\", value: item[\"TBT DESKTOP\"], operator: \"greater\", threshold: 100, unit: \"ms\" },\n  { name: \"CLS DESKTOP\", value: item[\"CLS DESKTOP\"], operator: \"greater\", threshold: 0.05, unit: \"\" },\n  { name: \"SPEED INDEX DESKTOP\", value: item[\"SPEED INDEX DESKTOP\"], operator: \"greater\", threshold: 1.5, unit: \"s\" },\n\n  // MOBILE\n  { name: \"SCORE GLOBAL MOBILE\", value: item[\"SCORE GLOBAL MOBILE\"], operator: \"less\", threshold: 90, unit: \"/100\" },\n  { name: \"SCORE FCP MOBILE\", value: item[\"SCORE FCP MOBILE\"], operator: \"greater\", threshold: 1.8, unit: \"s\" },\n  { name: \"SCORE LCP MOBILE\", value: item[\"SCORE LCP MOBILE\"], operator: \"greater\", threshold: 2.5, unit: \"s\" },\n  { name: \"TBT MOBILE\", value: item[\"TBT MOBILE\"], operator: \"greater\", threshold: 200, unit: \"ms\" },\n  { name: \"CLS MOBILE\", value: item[\"CLS MOBILE\"], operator: \"greater\", threshold: 0.1, unit: \"\" },\n  { name: \"SPEED INDEX MOBILE\", value: item[\"SPEED INDEX MOBILE\"], operator: \"greater\", threshold: 3, unit: \"s\" }\n];\n\nconst anomalies = checks.filter(check => {\n  const value = Number(String(check.value).replace(\",\", \".\"));\n\n  if (Number.isNaN(value)) {\n    return false;\n  }\n\n  if (check.operator === \"less\") {\n    return value < check.threshold;\n  }\n\n  if (check.operator === \"greater\") {\n    return value > check.threshold;\n  }\n\n  return false;\n});\n\nitem.alertePerformance = anomalies.length > 0;\nitem.nombreAnomaliesPerformance = anomalies.length;\nitem.anomaliesPerformance = anomalies.map(a => {\n  const value = Number(String(a.value).replace(\",\", \".\"));\n  const signe = a.operator === \"less\" ? \"<\" : \">\";\n  return `${a.name} : ${value}${a.unit} ${signe} seuil ${a.threshold}${a.unit}`;\n});\n\nreturn [{ json: item }];"
      },

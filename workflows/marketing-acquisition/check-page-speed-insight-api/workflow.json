        "jsCode": "const data = $input.first().json;\nconst audits = data.lighthouseResult.audits;\n\nreturn [{\n  json: {\n    \"url\": data.url,\n    \"date\": data.analysisUTCTimestamp,\n    \"SCORE GLOBAL MOBILE\": Math.round(data.lighthouseResult.categories.performance.score * 100),\n    \"SCORE FCP MOBILE\":    parseFloat((audits[\"first-contentful-paint\"].numericValue / 1000).toFixed(2)),\n    \"SCORE LCP MOBILE\":    parseFloat((audits[\"largest-contentful-paint\"].numericValue / 1000).toFixed(2)),\n    \"TBT MOBILE\":          Math.round(audits[\"total-blocking-time\"].numericValue), // Conservé en ms\n    \"CLS MOBILE\":          parseFloat(audits[\"cumulative-layout-shift\"].numericValue.toFixed(3)),\n    \"SPEED INDEX MOBILE\":  parseFloat((audits[\"speed-index\"].numericValue / 1000).toFixed(2)),\n  }\n}];"
      },

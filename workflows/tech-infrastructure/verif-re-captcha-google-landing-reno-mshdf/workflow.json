      "parameters": {
        "jsCode": "// ============================================================\n// VÉRIFICATION RECAPTCHA CÔTÉ SERVEUR\n// ============================================================\n\nconst { recaptchaToken } = $input.first().json.body;\n\nif (!recaptchaToken) {\n    return [{ json: { valid: false, reason: 'Token manquant' } }];\n}\n\nreturn [{\n    json: {\n        ...$input.first().json.body,\n        assessmentBody: {\n            event: {\n                token: recaptchaToken,\n                siteKey: 'YOUR_RECAPTCHA_SITE_KEY',\n                expectedAction: 'SUBMIT_QUOTE'\n            }\n        }\n    }\n}];"
      },
      "id": "873e23bf-2d0c-4964-a8dd-4b9e36111059",
      "name": "Code JS - Vérifie reCAPTCHA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-976, -32]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Webhook - Réception Lead').first().json.body;\n\nconst typeLabels = {\n    'Complete':   'Rénovation complète',\n    'Partielle':  'Rénovation partielle',\n    'SDB':        'Salle de bain',\n    'ElecPlomb':  'Électricité / Plomberie',\n    'Sol':        'Pose de sol',\n    'Dressing':   'Dressing',\n    'Autre':      'Autre'\n};\n\nconst budgetLabels = {\n    '5-10k':  '5 000 – 10 000 €',\n    '10-20k': '10 000 – 20 000 €',\n    '20-50k': '20 000 – 50 000 €',\n    '50k+':   'Plus de 50 000 €',\n    'nsp':    'Je ne sais pas encore'\n};\n\nconst budgetMap = {\n    '5-10k':  7500,\n    '10-20k': 15000,\n    '20-50k': 35000,\n    '50k+':   75000,\n    'nsp':    0\n};\n\nconst amount = budgetMap[d.budget] || 0;\nconst typeLabel = typeLabels[d.type] || d.type || 'Non précisé';\nconst budgetLabel = budgetLabels[d.budget] || d.budget || 'Non précisé';\nconst description = d.description || 'Aucune description fournie';\nconst telephone = d.telephone || 'Non renseigné';\nconst email = d.email || 'Non renseigné';\n\nconst htmlBody = `\n<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n  <div style=\"background: #ea580c; padding: 20px; border-radius: 8px 8px 0 0;\">\n    <h2 style=\"color: white; margin: 0;\">🔔 Nouveau Lead MSHDF</h2>\n    <p style=\"color: rgba(255,255,255,0.8); margin: 5px 0 0 0;\">Reçu le ${new Date().toLocaleDateString('fr-FR')} à ${new Date().toLocaleTimeString('fr-FR')}</p>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 24px; border: 1px solid #e9ecef;\">\n    <table style=\"width: 100%; border-collapse: collapse;\">\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057; width: 40%;\">👤 Nom</td>\n        <td style=\"padding: 12px 0; color: #212529;\">${d.nom || 'Non renseigné'}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">📧 Email</td>\n        <td style=\"padding: 12px 0;\"><a href=\"mailto:${email}\" style=\"color: #ea580c;\">${email}</a></td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">📞 Téléphone</td>\n        <td style=\"padding: 12px 0;\"><a href=\"tel:${telephone}\" style=\"color: #ea580c;\">${telephone}</a></td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">🔨 Type de projet</td>\n        <td style=\"padding: 12px 0;\">${typeLabel}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">💰 Budget estimé</td>\n        <td style=\"padding: 12px 0;\">${budgetLabel}</td>\n      </tr>\n    </table>\n    <div style=\"margin-top: 20px;\">\n      <p style=\"font-weight: bold; color: #495057; margin-bottom: 8px;\">📝 Description du projet :</p>\n      <div style=\"background: white; border: 1px solid #dee2e6; border-radius: 6px; padding: 16px; color: #212529; line-height: 1.6;\">${description.replace(/\\n/g, '<br>')}</div>\n    </div>\n  </div>\n  <div style=\"background: #343a40; padding: 16px; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"color: rgba(255,255,255,0.6); margin: 0; font-size: 12px;\">Lead généré depuis renovation.emarenovation59.fr • reCAPTCHA score: ${d.recaptchaScore || 'N/A'}</p>\n  </div>\n</div>`;\n\nreturn [{\n    json: {\n        ...d,\n        amount,\n        emailSubject: `🔔 Nouveau lead MSHDF - ${typeLabel} - ${d.nom || 'Inconnu'}`,\n        emailHtml: htmlBody,\n        emailText: `Nouveau lead MSHDF\\nNom: ${d.nom}\\nEmail: ${email}\\nTél: ${telephone}\\nProjet: ${typeLabel}\\nBudget: ${budgetLabel}\\nDescription: ${description}`\n    }\n}];"
      },

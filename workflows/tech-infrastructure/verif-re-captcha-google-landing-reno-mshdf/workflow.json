      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst score = data.riskAnalysis?.score ?? 0;\nconst tokenValid = data.tokenProperties?.valid === true;\nconst invalidReason = data.tokenProperties?.invalidReason || '';\n\nif (!tokenValid) {\n    return [{ json: { valid: false, score, reason: invalidReason } }];\n}\n\nif (score < 0.5) {\n    return [{ json: { valid: false, score, reason: 'Score trop bas' } }];\n}\n\nreturn [{ json: { ...$input.first().json, valid: true, score } }];"
      },

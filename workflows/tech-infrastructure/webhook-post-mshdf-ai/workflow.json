      ],
      "id": "269474cf-12aa-4539-9cec-504de54b28fa",
      "name": "Code JS - Prépare prompt Claude"
    },
    {
      "parameters": {
        "jsCode": "const ip = ($input.first().json.headers?.['x-forwarded-for']?.split(',')[0] || 'unknown')\n    .trim()\n    .replace(/\\./g, '_');\n\nconst now = Date.now();\nconst key = `ai_${ip}`;\nconst last = $execution.customData.get(key) || 0;\n\nif (now - last < 4000) {\n    return [{ json: { blocked: true, text: '' } }];\n}\n\n$execution.customData.set(key, now);\nreturn [{ json: { ...$input.first().json, blocked: false } }];"
      },

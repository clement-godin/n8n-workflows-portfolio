    {
      "parameters": {
        "jsCode": "const { userPrompt, systemPrompt } = $input.first().json.body;\n\nconst cleanPrompt = (str) => (str || '')\n    .replace(/[\\r\\n\\t]/g, ' ')\n    .replace(/\"/g, \"'\")\n    .replace(/\\s+/g, ' ')\n    .trim();\n\nconst antiMarkdown = \" IMPORTANT : Reponds en texte brut uniquement. Aucun markdown. Pas de **, pas de *, pas de #. Uniquement du texte et des tirets simples si necessaire.\";\n\nreturn [{\n    json: {\n        claudeBody: {\n            model: 'claude-haiku-4-5-20251001',\n            max_tokens: 300,\n            system: cleanPrompt(systemPrompt) + antiMarkdown,\n            messages: [{\n                role: 'user',\n                content: cleanPrompt(userPrompt)\n            }]\n        }\n    }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,

      {
        "parameters": {
          "jsCode": "// 1. Récupération des données\nconst allBlocks = $input.all();\n// ⚠️ Vérifiez que ce nom correspond à votre nœud de liste des pages (N°4)\nconst allPages = $items(\"Code JS - Extrait titres\"); \n// ⚠️ Vérifiez que ce nom correspond à votre nœud de fusion (celui avec les IDs Drive)\nconst mergedData = $items(\"Merge - Notion + Drive\"); \n\n// --- A. Carte des Dossiers (ID Notion -> ID Drive) ---\nconst folderMap = {};\nfor (const item of mergedData) {\n    // On cherche l'ID Notion (soit dans 'id', soit dans l'URL si écrasé)\n    let notionId = item.json.id;\n    if (notionId && !notionId.includes('-') && item.json.url) {\n        notionId = item.json.url.slice(-32);\n    }\n    // On cherche l'ID Drive (renommé 'driveFolderId' ou dans le 2ème id)\n    const driveId = item.json.driveFolderId || item.json.id; \n    \n    if (notionId && driveId) folderMap[notionId] = driveId;\n}\n\n// --- B. Tri des blocs par page ---\nconst blocksByPage = {};\nfor (const item of allBlocks) {\n    const block = item.json;\n    if (block?.parent?.type === 'page_id') {\n        const pid = block.parent.page_id;\n        if (!blocksByPage[pid]) blocksByPage[pid] = [];\n        blocksByPage[pid].push(block);\n    }\n}\n\nconst results = [];\n\n// --- C. Boucle Principale sur les 83 pages ---\nfor (const pageItem of allPages) {\n    const pageId = pageItem.json.id;\n    \n    // 1. Nettoyage du Titre\n    let pageTitle = pageItem.json.pageTitle || `Page_${pageId}`;\n    // Si le titre est un tableau (cas rare), on prend le texte\n    if (Array.isArray(pageTitle) && pageTitle.length > 0) pageTitle = pageTitle[0];\n    pageTitle = typeof pageTitle === 'string' ? pageTitle.replace(/[\\/\\\\|:?\"*<>]/g, \"_\").trim() : `Page_${pageId}`;\n    \n    // 2. Identification du Dossier Parent\n    const parentDbId = pageItem.json.parent ? pageItem.json.parent.database_id : \"Inconnu\";\n    // On récupère l'ID du dossier \"Base de Données\" (ex: dossier 'Clients')\n    const dbFolderId = folderMap[parentDbId] || \"\"; \n\n    // 3. Construction du JSON Complet (Master File)\n    const pageBlocks = blocksByPage[pageId] || [];\n    const fullPageData = {\n        meta: {\n            id: pageId,\n            title: pageTitle,\n            database_id: parentDbId,\n            url: pageItem.json.url,\n            created_time: pageItem.json.created_time,\n            properties: pageItem.json.properties || {}\n        },\n        content: {\n            total_blocks: pageBlocks.length,\n            blocks: pageBlocks.map(b => b.json)\n        }\n    };\n    \n    // Conversion en Binaire\n    const jsonString = JSON.stringify(fullPageData, null, 2);\n    const binaryData = Buffer.from(jsonString).toString('base64');\n\n    // 4. Extraction des fichiers à télécharger (Propriétés + Blocs)\n    const filesList = [];\n    \n    // a) Fichiers dans les Propriétés\n    const props = pageItem.json.properties || {};\n    for (const key in props) {\n        if (props[key].type === 'files' && props[key].files) {\n            for (const file of props[key].files) {\n                const url = file.file?.url || file.external?.url;\n                if (url) filesList.push({ url: url, name: `PROP_${file.name}` });\n            }\n        }\n    }\n    \n    // b) Fichiers dans les Blocs\n    for (const block of pageBlocks) {\n        if (['image', 'file', 'pdf', 'video'].includes(block.type)) {\n            const content = block[block.type];\n            const url = content.file?.url || content.external?.url;\n            if (url) {\n                let name = content.caption?.[0]?.plain_text || `${block.type}_${block.id}`;\n                // Ajout extension basique si absente\n                if (!name.includes('.')) name += block.type === 'pdf' ? '.pdf' : '.png';\n                filesList.push({ url: url, name: `BLOC_${name}` });\n            }\n        }\n    }\n\n    // 5. Sortie de l'item\n    results.push({\n        json: {\n            pageTitle: pageTitle,\n            dbFolderId: dbFolderId, // C'est la variable pour le dossier parent !\n            filesToDownload: filesList\n        },\n        binary: {\n            data: {\n                data: binaryData,\n                mimeType: 'application/json',\n                fileExtension: 'json',\n                fileName: `${pageTitle}_Full.json`\n            }\n        }\n    });\n}\n\nreturn results;"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,

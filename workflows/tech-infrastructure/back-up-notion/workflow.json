      {
        "parameters": {
          "jsCode": "// Récupère tous les items (pages) entrants\nconst items = $input.all();\n\n// On boucle sur chaque page\nfor (const item of items) {\n  const properties = item.json.properties;\n  let pageTitle = '';\n  let filesToDownload = [];\n\n  // S'assurer que properties existe (sécurité)\n  if (properties) {\n    // 1. Boucle sur toutes les propriétés pour trouver le TITRE et les FICHIERS\n    for (const propName in properties) {\n      const prop = properties[propName];\n\n      // --- Trouve la propriété TITRE ---\n      if (prop.type === 'title') {\n        if (prop.title && prop.title.length > 0) {\n          pageTitle = prop.title.map(t => t.plain_text).join('');\n        }\n      }\n\n      // --- Trouve les propriétés FICHIERS ---\n      if (prop.type === 'files' && prop.files && prop.files.length > 0) {\n        for (const file of prop.files) {\n          const url = file.type === 'file' ? file.file.url : file.external.url;\n          filesToDownload.push({ \n            name: file.name, \n            url: url \n          });\n        }\n      }\n    }\n  }\n\n  // 2. Ajoute les résultats dans des champs faciles à utiliser\n  item.json.pageTitle = pageTitle || 'Page_Sans_Titre_' + item.json.id;\n  item.json.filesToDownload = filesToDownload;\n}\n\nreturn items;"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -1120,
          80
        ],
        "id": "303a6a5b-ac74-4abf-8076-f78e081c0e74",

        "jsCode": "const body = $input.first().json.body;\nconst recaptchaToken = body.recaptchaToken;\n\nif (!recaptchaToken) {\n  return [{ json: { valid: false, reason: 'Token manquant', ...body } }];\n}\n\nreturn [{\n  json: {\n    ...body,\n    assessmentBody: {\n      event: {\n        token: recaptchaToken,\n        siteKey: '6LcvqPIsAAAAAJsyRhXcCz-Bv-rEStpn4oZlQ0SZ',\n        expectedAction: 'SUBMIT_DEVIS'\n      }\n    }\n  }\n}];"
      },

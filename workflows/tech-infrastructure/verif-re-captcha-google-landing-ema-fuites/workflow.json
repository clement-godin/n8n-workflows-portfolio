    {
      "parameters": {
        "jsCode": "const d = $('Webhook - Réception Lead').first().json.body;\n\nconst sourcePage = d.source_page || 'Non renseigné';\nconst utmTerm = d.utm_term || 'Direct';\nconst utmSource = d.utm_source || 'Direct';\nconst utmCampaign = d.utm_campaign || 'Non renseigné';\nconst telephone = d.telephone || 'Non renseigné';\nconst ville = d.ville || 'Non renseigné';\nconst description = d.description || 'Aucune description fournie';\nconst score = $('Code JS - Évalue score').first().json.recaptchaScore || 0;\n\nconst pageLabels = {\n  '/fuite-sous-carrelage': '🔵 Fuite sous carrelage',\n  '/fuite-canalisation': '🔵 Fuite canalisation',\n  '/fuite-toiture-terrasse': '🔵 Fuite toiture terrasse',\n  '/fuite-plancher-chauffant': '🔵 Fuite plancher chauffant',\n  '/infiltration-humidite-mur': '🔵 Humidité / Infiltration mur',\n  '/recherche-fuite-non-destructive': '🔵 Recherche fuite générique'\n};\n\nconst pageLabel = pageLabels[sourcePage] || sourcePage;\n\nconst htmlBody = `\n<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n  <div style=\"background: linear-gradient(135deg, #071a2e, #00b894); padding: 20px; border-radius: 8px 8px 0 0;\">\n    <h2 style=\"color: white; margin: 0;\">🔔 Nouveau Lead EMA Fuites</h2>\n    <p style=\"color: rgba(255,255,255,0.8); margin: 5px 0 0 0;\">Reçu le ${new Date().toLocaleDateString('fr-FR')} à ${new Date().toLocaleTimeString('fr-FR')}</p>\n  </div>\n  <div style=\"background: #f8f9fa; padding: 24px; border: 1px solid #e9ecef;\">\n    <table style=\"width: 100%; border-collapse: collapse;\">\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057; width: 40%;\">👤 Nom</td>\n        <td style=\"padding: 12px 0; color: #212529;\">${d.nom || 'Non renseigné'}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">📞 Téléphone</td>\n        <td style=\"padding: 12px 0;\"><a href=\"tel:${telephone}\" style=\"color: #00b894;\">${telephone}</a></td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">📍 Ville</td>\n        <td style=\"padding: 12px 0;\">${ville}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">📄 Page source</td>\n        <td style=\"padding: 12px 0;\">${pageLabel}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">🔍 Mot-clé Google</td>\n        <td style=\"padding: 12px 0;\">${utmTerm}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">📊 Campagne</td>\n        <td style=\"padding: 12px 0;\">${utmCampaign}</td>\n      </tr>\n      <tr style=\"border-bottom: 1px solid #dee2e6;\">\n        <td style=\"padding: 12px 0; font-weight: bold; color: #495057;\">🛡 Score reCAPTCHA</td>\n        <td style=\"padding: 12px 0; color: ${score >= 0.7 ? '#00b894' : score >= 0.5 ? '#f39c12' : '#e74c3c'}\">${score} / 1.0</td>\n      </tr>\n    </table>\n    <div style=\"margin-top: 20px;\">\n      <p style=\"font-weight: bold; color: #495057; margin-bottom: 8px;\">📝 Description du problème :</p>\n      <div style=\"background: white; border: 1px solid #dee2e6; border-radius: 6px; padding: 16px; color: #212529; line-height: 1.6;\">${description.replace(/\\n/g, '<br>')}</div>\n    </div>\n  </div>\n  <div style=\"background: #071a2e; padding: 16px; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"color: rgba(255,255,255,0.6); margin: 0; font-size: 12px;\">Lead généré depuis ema-fuites.fr${sourcePage} • Source: ${utmSource}</p>\n  </div>\n</div>`;\n\nreturn [{\n    json: {\n        ...d,\n        recaptchaScore: score,\n        pageLabel,\n        emailSubject: `🔔 Nouveau lead EMA Fuites - ${pageLabel} - ${d.nom || 'Inconnu'}`,\n        emailHtml: htmlBody,\n        emailText: `Nouveau lead EMA Fuites\\nNom: ${d.nom}\\nTél: ${telephone}\\nVille: ${ville}\\nPage: ${sourcePage}\\nMot-clé: ${utmTerm}\\nDescription: ${description}`\n    }\n}];"
      },

        "jsCode": "const response = $input.first().json;\nconst score = response.riskAnalysis?.score || 0;\nconst tokenValid = response.tokenProperties?.valid === true;\nconst valid = score >= 0.5 && tokenValid;\n\nconst leadData = $('Code JS - Vérifie reCAPTCHA').first().json;\n\nreturn [{\n    json: {\n        ...leadData,\n        recaptchaScore: score,\n        valid: valid\n    }\n}];"

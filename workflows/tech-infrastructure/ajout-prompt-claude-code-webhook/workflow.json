    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst required = ['titre', 'repertoire_projet', 'prompt'];\nfor (const field of required) {\n  if (!body[field] || String(body[field]).trim() === '') {\n    return [{ json: { __error: true, message: `Champ requis manquant : ${field}` } }];\n  }\n}\n\nconst modeles = ['sonnet', 'opus', 'haiku'];\nlet modele = String(body.modele || '').toLowerCase().trim();\nif (!modeles.includes(modele)) modele = 'sonnet';\n\nconst priorites = ['haute', 'moyenne', 'basse'];\nlet priorite = String(body.priorite || '').toLowerCase().trim();\nif (!priorites.includes(priorite)) priorite = 'moyenne';\n\nconst slugify = (str) => str\n  .normalize('NFD').replace(/[̀-ͯ]/g, '')\n  .toLowerCase()\n  .replace(/[^a-z0-9\\s-]/g, '')\n  .trim()\n  .replace(/\\s+/g, '-')\n  .substring(0, 40);\n\nconst now = new Date();\nconst ts = now.toISOString().replace(/[-:T.Z]/g, '').substring(0, 14);\nconst id = `${slugify(body.titre)}-${ts}`;\n\nconst dd = String(now.getDate()).padStart(2, '0');\nconst mm = String(now.getMonth() + 1).padStart(2, '0');\nconst yyyy = now.getFullYear();\nconst date_creation = `${dd}/${mm}/${yyyy}`;\n\nreturn [{\n  json: {\n    __error: false,\n    id,\n    titre: String(body.titre).trim(),\n    repertoire_projet: String(body.repertoire_projet).trim(),\n    prompt: String(body.prompt).trim(),\n    modele,\n    priorite,\n    statut: 'à faire',\n    date_creation,\n    date_lancement: '',\n    date_fin: '',\n    resume: '',\n    erreur: ''\n  }\n}];"
      },

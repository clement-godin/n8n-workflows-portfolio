        "jsCode": "const usage = $json.usage;\nconst cachedTokens = usage.prompt_cache_hit_tokens || 0;\nconst promptTokens = usage.prompt_tokens || 1;\nconst cacheRatio = cachedTokens / promptTokens;\n\nconst staticData = $getWorkflowStaticData('global');\nconst tentatives = staticData.tentatives || 0;\nstaticData.tentatives = tentatives + 1;\n\nconst cacheChaud = cacheRatio > 0.7 || tentatives >= 3;\nif (cacheChaud) staticData.tentatives = 0;\n\nreturn {\n  json: {\n    cache_chaud: cacheChaud,\n    cache_ratio: Math.round(cacheRatio * 100),\n    cached_tokens: cachedTokens,\n    prompt_tokens: promptTokens,\n    tentatives: tentatives + 1\n  }\n};"

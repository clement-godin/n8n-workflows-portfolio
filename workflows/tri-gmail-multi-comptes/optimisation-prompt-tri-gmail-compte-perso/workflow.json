    {
      "parameters": {
        "jsCode": "const prompt = $('Google Sheets - Prompt Actif').first().json;\nconst rows   = $('Google Sheets - Classifications à analyser').all();\n\nconst total     = rows.length;\nconst erronees  = rows.filter(r => (r.json['correct'] || r.json['correct '] || '').trim() === 'non');\nconst incertain = rows.filter(r => (r.json['correct'] || r.json['correct '] || '').trim() === '?');\nconst correctes = rows.filter(r => (r.json['correct'] || r.json['correct '] || '').trim() === 'oui');\n\nconst tauxErreur = total > 0 ? ((erronees.length / total) * 100).toFixed(1) : 0;\n\nconst erreursByCategorie = {};\nfor (const r of erronees) {\n  const cat = r.json.categorie_attribuee;\n  if (!erreursByCategorie[cat]) erreursByCategorie[cat] = [];\n  erreursByCategorie[cat].push({\n    sujet:       r.json.sujet,\n    corps:       r.json.corps_resume,\n    commentaire: r.json.commentaire\n  });\n}\n\nconst exemplesErreurs = erronees.slice(0, 10).map(r => ({\n  sujet:               r.json.sujet,\n  corps:               r.json.corps_resume,\n  categorie_attribuee: r.json.categorie_attribuee,\n  commentaire:         r.json.commentaire\n}));\n\nconst rowNumbers = rows.map(r => r.json.row_number).filter(Boolean);\n\nreturn [{\n  json: {\n    prompt_actuel:    prompt.Prompt,\n    prompt_version:   prompt.Version || 'v1',\n    row_number_prompt: prompt.row_number,\n    total,\n    nb_correctes:     correctes.length,\n    nb_erronees:      erronees.length,\n    nb_incertain:     incertain.length,\n    taux_erreur:      tauxErreur,\n    erreurs_by_cat:   erreursByCategorie,\n    exemples_erreurs: exemplesErreurs,\n    row_numbers:      rowNumbers\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1264, 784],
      "id": "776fa5ba-6642-4824-a109-cb6fa6cd5ba2",

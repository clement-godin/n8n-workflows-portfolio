      "name": "API DeepSeek - Analyse prompt",
      "credentials": {
        "deepSeekApi": { "id": "MBt6ozX97KVIAwcD", "name": "DeepSeek account" }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw     = $input.first().json.choices[0].message.content\n  .trim()\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```\\s*$/i, '');\n\nconst rapport = $('Code JS - Calcule statistiques').first().json;\n\nlet analyse;\ntry {\n  analyse = JSON.parse(raw);\n} catch(e) {\n  analyse = {\n    modification_necessaire: false,\n    analyse: 'Erreur de parsing — vérification manuelle requise',\n    problemes: [],\n    prompt_modifie: '',\n    diff: [],\n    confiance: 'faible'\n  };\n}\n\n// Ajoute ces lignes avant le return\nconst staticData = $getWorkflowStaticData('global');\nstaticData.row_numbers = rapport.row_numbers || [];\n\nreturn [{\n  json: {\n    ...analyse,\n    prompt_actuel:      rapport.prompt_actuel,\n    prompt_version:     rapport.prompt_version,\n    row_number_prompt:  rapport.row_number_prompt,\n    row_numbers:        rapport.row_numbers,\n    stats: {\n      total:       rapport.total,\n      taux_erreur: rapport.taux_erreur\n    }\n  }\n}];"
      },

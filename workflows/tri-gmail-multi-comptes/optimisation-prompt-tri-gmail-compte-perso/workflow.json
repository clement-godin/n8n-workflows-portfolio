    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\n// Persistance pour le callback Telegram\nconst staticData = $getWorkflowStaticData('global');\nstaticData.prompt_modifie  = d.prompt_modifie;\nstaticData.prompt_version  = d.prompt_version;\nstaticData.row_number      = d.row_number_prompt;\nstaticData.row_numbers     = d.row_numbers;\n\nconst problemes = (d.problemes || []).map((p, i) => `${i+1}. ${p}`).join('\\n');\nconst diffs     = (d.diff || []).map((diff, i) => `${i+1}. ${diff}`).join('\\n');\n\nconst semaine = $now.minus({days: 7}).toFormat('dd/MM');\n\nconst message =\n`🔍 <b>Analyse prompt classif — semaine du ${semaine}</b>\\n\\n` +\n`📊 <b>Stats</b>\\n` +\n`Taux d'erreur : ${d.stats.taux_erreur}% sur ${d.stats.total} emails\\n\\n` +\n`⚠️ <b>Problèmes détectés</b>\\n${problemes}\\n\\n` +\n`✏️ <b>Modifications proposées</b>\\n${diffs}\\n\\n` +\n`🎯 Confiance de l'analyse : ${d.confiance}\\n\\n` +\n`<b>Valider la mise à jour du prompt ?</b>`;\n\nreturn [{ json: { message, prompt_modifie: d.prompt_modifie, row_numbers: d.row_numbers } }];"
      },

        "jsCode": "const d = $input.first().json;\n\nconst body = {\n  model: \"deepseek-v4-flash\",\n  temperature: 0.3,\n  messages: [\n    {\n      role: \"system\",\n      content: \"Tu es un expert en prompt engineering et classification d'emails. Tu analyses les résultats de classification d'une semaine, identifies les patterns d'erreurs, et proposes des améliorations précises au prompt de classification. Tu réponds UNIQUEMENT en JSON valide sans backticks ni texte autour.\"\n    },\n    {\n      role: \"user\",\n      content: \"Voici le rapport de classification de la semaine :\\n\\nPROMPT ACTUEL (\" + d.prompt_version + \") :\\n\" + d.prompt_actuel + \"\\n\\nSTATISTIQUES :\\n- Total emails classifiés : \" + d.total + \"\\n- Corrects : \" + d.nb_correctes + \"\\n- Erreurs confirmées : \" + d.nb_erronees + \"\\n- Incertains : \" + d.nb_incertain + \"\\n- Taux d'erreur : \" + d.taux_erreur + \"%\\n\\nERREURS PAR CATÉGORIE :\\n\" + JSON.stringify(d.erreurs_by_cat, null, 2) + \"\\n\\nEXEMPLES D'ERREURS :\\n\" + JSON.stringify(d.exemples_erreurs, null, 2) + \"\\n\\nRéponds avec ce JSON :\\n{\\\"modification_necessaire\\\": true/false,\\\"analyse\\\": \\\"résumé des problèmes détectés en 3-4 phrases\\\",\\\"problemes\\\": [\\\"problème 1\\\"],\\\"prompt_modifie\\\": \\\"le prompt complet réécrit\\\",\\\"diff\\\": [\\\"modification 1\\\"],\\\"confiance\\\": \\\"haute/moyenne/faible\\\"}\"\n    }\n  ]\n};\n\nreturn [{ json: { ...d, requestBody: JSON.stringify(body) } }];"

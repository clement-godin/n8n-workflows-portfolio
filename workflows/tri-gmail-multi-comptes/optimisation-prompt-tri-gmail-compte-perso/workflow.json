      "name": "Google Sheets - Classifications à analyser",
      "executeOnce": true,
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "rCFvQBVaQVzg9Lrq", "name": "CLIENT OAUTH COMPTE GOOGLE SHEET EMAFUITES" }

      },
      {
        "parameters": {
          "jsCode": "const tomorrow = new Date();\ntomorrow.setDate(tomorrow.getDate() + 1);\n\n// Exclure si demain c'est samedi ou dimanche\nconst dow = tomorrow.getDay();\nif (dow === 0 || dow === 6) {\n  return [{ json: { skip: true } }];\n}\n\nreturn [{\n  json: {\n    skip: false,\n    date_demain: tomorrow.toISOString().split('T')[0], // YYYY-MM-DD\n    date_label: tomorrow.toLocaleDateString('fr-FR', {\n      weekday: 'long', day: 'numeric', month: 'long'\n    }),\n  }\n}];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          224,
          0
        ],
        "id": "060dbc74-fc4a-42f0-b0ad-74845906d8fe",
        "name": "Code - Date demain"
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "version": 3,
              "leftValue": "",
              "caseSensitive": true,
              "typeValidation": "strict"
            },
            "conditions": [
              {
                "id": "867c2a5a-6e0d-4424-8f3d-04ee81a5dbe6",
                "leftValue": "={{ $json.skip }}",
                "rightValue": "",
                "operator": {
                  "type": "boolean",
                  "operation": "false",
                  "singleValue": true
                }
              }
            ],
            "combinator": "and"
          },
          "options": {}
        },
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.3,
        "position": [
          448,

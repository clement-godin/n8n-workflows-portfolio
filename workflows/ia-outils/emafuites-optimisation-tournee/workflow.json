    {
      "parameters": {
        "jsCode": "const trigger = $('HubSpot Trigger').first().json;\n\nconst lat = trigger.properties.rdv_lat ||\n  $('HTTP Request - Nominatim').first().json[0]?.lat;\nconst lng = trigger.properties.rdv_lng ||\n  $('HTTP Request - Nominatim').first().json[0]?.lon;\n\nreturn [{\n  json: {\n    dealId: trigger.id,\n    rdv_lat: parseFloat(lat),\n    rdv_lng: parseFloat(lng),\n    rdv_adresse: trigger.properties.rdv_adresse,\n    rdv_date: trigger.properties.rdv_date,\n    duree_intervention: parseInt(trigger.properties.duree_intervention) || 60,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1328,
        -128
      ],
      "id": "2819edf5-da1a-4631-b0a5-7861758fd329",
      "name": "Code - Normaliser deal"
    },
    {
      "parameters": {
        "url": "https://api.hubapi.com/crm/v3/objects/deals/search",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "hubspotAppToken",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"filterGroups\": [{\n    \"filters\": [\n      {\n        \"propertyName\": \"rdv_date\",\n        \"operator\": \"EQ\",\n        \"value\": \"{{ $json.rdv_date }}\"\n      },\n      {\n        \"propertyName\": \"rdv_lat\",\n        \"operator\": \"HAS_PROPERTY\"\n      }\n    ]\n  }],\n  \"properties\": [\n    \"rdv_lat\", \"rdv_lng\", \"rdv_date\",\n    \"technicien_assigne\", \"duree_intervention\"\n  ],\n  \"limit\": 100\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1520,
        -128
      ],
      "id": "2deb69c1-9cc4-4026-97dd-f8a2e03cded1",
      "name": "API HubSpot - Cherche deals date",
      "credentials": {
        "hubspotAppToken": {
          "id": "JnaOUFzIE4lA3O1R",
          "name": "HubSpot account EMA FUITES"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const deals = $input.first().json.results || [];\nconst current = $('Code - Normaliser deal').first().json;\n\nconst others = deals.filter(d => d.id !== current.dealId);\n\nconst tech1Jobs = others.filter(d => d.properties.technicien_assigne === 'tech1');\nconst tech2Jobs = others.filter(d => d.properties.technicien_assigne === 'tech2');\n\nconst assignTo = tech1Jobs.length <= tech2Jobs.length ? 'tech1' : 'tech2';\n\nconst existingJobs = others.filter(d => d.properties.technicien_assigne === assignTo);\n\nconst allJobs = [\n  ...existingJobs.map(d => ({\n    id: parseInt(d.id),\n    lat: parseFloat(d.properties.rdv_lat),\n    lng: parseFloat(d.properties.rdv_lng),\n    duree: parseInt(d.properties.duree_intervention) || 60,\n    dealId: d.id,\n  })),\n  {\n    id: parseInt(current.dealId),\n    lat: current.rdv_lat,\n    lng: current.rdv_lng,\n    duree: current.duree_intervention,\n    dealId: current.dealId,\n  }\n];\n\nreturn [{ json: { assignTo, allJobs, newDealId: current.dealId, rdv_date: current.rdv_date } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1728,
        -128
      ],
      "id": "dfb5b16f-1ba5-46a1-8670-aa5f01c6a6b3",
      "name": "Code - Assigne technicien"
    },
    {
      "parameters": {
        "jsCode": "const { assignTo, allJobs, newDealId, rdv_date } = $input.first().json;\n\n// À REMPLACER PAR LES COORDONNÉES GPS RÉELLES DE VOS TECHNICIENS (point de départ/retour de tournée)\nconst techHomes = {\n  tech1: { lng: 0.0000, lat: 0.0000 }, // YOUR_TECH1_HOME_COORDS\n  tech2: { lng: 0.0000, lat: 0.0000 }, // YOUR_TECH2_HOME_COORDS\n};\n\nconst home = techHomes[assignTo];\n\nconst payload = {\n  vehicles: [{\n    id: 1,\n    profile: 'car',\n    start: [home.lng, home.lat],\n    end:   [home.lng, home.lat],\n    time_window: [28800, 64800],\n  }],\n  jobs: allJobs.map(j => ({\n    id: j.id,\n    location: [j.lng, j.lat],\n    service: j.duree * 60,\n  })),\n};\n\nreturn [{ json: { payload, assignTo, allJobs, newDealId, rdv_date } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1936,
        -128
      ],

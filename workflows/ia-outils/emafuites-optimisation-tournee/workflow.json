      "id": "9c8ab2ad-3914-4370-bb6c-9b5f863d91b1",
      "name": "API Vroom - Optimise route"
    },
    {
      "parameters": {
        "jsCode": "const vroomResponse = $input.first().json;\nconst { assignTo, allJobs, newDealId, rdv_date } = $('Code - Build Vroom Payload').first().json;\n\nfunction secondsToISO(seconds, dateStr) {\n  const base = new Date(dateStr);\n  base.setHours(0, 0, 0, 0);\n  base.setSeconds(base.getSeconds() + seconds);\n  return base.toISOString();\n}\n\nconst steps = vroomResponse.routes[0].steps.filter(s => s.type === 'job');\n\nconst updates = steps.map((step, index) => {\n  const job = allJobs.find(j => j.id === step.job);\n  return {\n    dealId: String(step.job),\n    ordre_tournee: index + 1,\n    eta_arrivee: secondsToISO(step.arrival, rdv_date),\n    technicien_assigne: assignTo,\n    duree_intervention: job?.duree || 60,\n  };\n});\n\nreturn updates.map(u => ({ json: u }));"
      },

    {
      "parameters": {
        "jsCode": "// Charge l'état de conversation\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.conversations) staticData.conversations = {};\n\nconst from        = $json.from;\nconst displayName = $json.display_name || 'Client';\nconst nonText     = $json.non_text || false;\nconst messageText = $json.message_text || '';\nconst msgLower    = messageText.toLowerCase();\n\nconst conv = staticData.conversations[from] || {\n  step: 'initial',\n  history: [],\n  nom: displayName,\n  telephone: from\n};\n\n// Commande de réinitialisation manuelle (permet de sortir du mode handover bloqué)\nconst RESET_KEYWORDS = ['reset', '#reset', 'recommencer'];\nif (!nonText && RESET_KEYWORDS.includes(msgLower.trim())) {\n  staticData.conversations[from] = {\n    step: 'initial',\n    history: [{ role: 'user', content: 'Bonjour' }],\n    nom: displayName,\n    telephone: from\n  };\n  return [{ json: {\n    from,\n    phone_number_id: $json.phone_number_id,\n    messageText: 'Bonjour',\n    displayName,\n    mode: 'ia',\n    conv: staticData.conversations[from],\n    demandeHandover: false,\n    skip_ia: false\n  }}];\n}\n\n// Détecte demande handover humain\nconst HANDOVER_KEYWORDS = [\n  'humain', 'personne', 'conseiller', 'rappel', 'rappelle',\n  'parler', 'quelquun', 'quelqu\\'un', 'agent', 'technicien',\n  'urgent', 'urgence', 'aide', 'help', 'sos'\n];\nconst demandeHandover = HANDOVER_KEYWORDS.some(k => msgLower.includes(k)) && conv.step !== 'handover';\n\n// Si déjà en handover humain, ignorer (le technicien répond directement)\nif (conv.step === 'handover') {\n  staticData.conversations[from] = conv;\n  return [{ json: {\n    from,\n    phone_number_id: $json.phone_number_id,\n    mode: 'handover_actif',\n    conv,\n    skip_ia: true\n  }}];\n}\n\nif (nonText) {\n  return [{ json: {\n    from,\n    phone_number_id: $json.phone_number_id,\n    response: \"Je traite uniquement les messages texte. Décrivez votre problème en quelques mots 😊\",\n    skip_ia: true,\n    conv\n  }}];\n}\n// Prépare l'historique pour DeepSeek\nconst history = conv.history || [];\nhistory.push({ role: 'user', content: messageText });\n\n// Sauvegarde état intermédiaire\nstaticData.conversations[from] = {\n  ...conv,\n  history,\n  nom: displayName\n};\n\nreturn [{ json: {\n  from,\n  phone_number_id: $json.phone_number_id,\n  messageText,\n  displayName,\n  mode: 'ia',\n  conv: staticData.conversations[from],\n  demandeHandover,\n  skip_ia: false\n}}];"
      },

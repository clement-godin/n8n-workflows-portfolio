    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nif (!body || body.object !== 'whatsapp_business_account') {\n  return [{ json: { valid: false, reason: 'not_whatsapp' } }];\n}\n\nconst entry = body.entry && body.entry[0];\nif (!entry) return [{ json: { valid: false, reason: 'no_entry' } }];\n\nconst change = entry.changes && entry.changes[0];\nif (!change || change.field !== 'messages') return [{ json: { valid: false, reason: 'no_messages_field' } }];\n\nconst value = change.value;\nif (value.statuses) return [{ json: { valid: false, reason: 'status_update' } }];\n\nconst messages = value.messages;\nif (!messages || !messages[0]) return [{ json: { valid: false, reason: 'no_message' } }];\n\nconst message = messages[0];\nconst contact  = value.contacts && value.contacts[0];\n\nif (message.type !== 'text') {\n  return [{ json: {\n    valid: true,\n    non_text: true,\n    from: message.from,\n    display_name: contact ? contact.profile.name : 'Client',\n    phone_number_id: value.metadata.phone_number_id\n  }}];\n}\n\nreturn [{ json: {\n  valid: true,\n  non_text: false,\n  from: message.from,\n  message_id: message.id,\n  message_text: message.text.body,\n  display_name: contact ? contact.profile.name : 'Client',\n  timestamp: message.timestamp,\n  phone_number_id: value.metadata.phone_number_id\n}}];"
      },
      "type": "n8n-nodes-base.code",

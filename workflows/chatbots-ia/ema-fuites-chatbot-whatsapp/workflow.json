    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.choices[0].message.content\n  .trim()\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```\\s*$/i, '');\n\nconst prev = $('Code JS - Prépare prompt DeepSeek').first().json;\nconst conv = prev.conv;\n\nlet ia;\ntry {\n  ia = JSON.parse(raw);\n} catch(e) {\n  ia = {\n    message: \"Je n'ai pas bien compris. Pouvez-vous reformuler ? 😊\",\n    type_fuite: null, ville: null, urgence: null,\n    qualified: false, hors_zone: false, besoin_humain: false\n  };\n}\n\n// Met à jour les données collectées\nconst updatedConv = {\n  ...conv,\n  type_fuite: ia.type_fuite || conv.type_fuite || null,\n  ville:      ia.ville      || conv.ville      || null,\n  urgence:    ia.urgence    || conv.urgence    || null\n};\n\n// Ajoute la réponse IA à l'historique\nif (!updatedConv.history) updatedConv.history = [];\nupdatedConv.history.push({ role: 'assistant', content: ia.message });\n\n// Détermine le prochain step\nlet newStep = conv.step || 'initial';\nif (ia.hors_zone || prev.demandeHandover)  newStep = 'handover';\nelse if (ia.qualified)                     newStep = 'done';\nelse                                        newStep = 'en_cours';\n\nupdatedConv.step = newStep;\n\n// Sauvegarde\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.conversations) staticData.conversations = {};\nstaticData.conversations[prev.from] = updatedConv;\n\nreturn [{ json: {\n  from:           prev.from,\n  phone_number_id: prev.phone_number_id,\n  response:       ia.message,\n  qualified:      ia.qualified || false,\n  hors_zone:      ia.hors_zone || false,\n  besoin_humain:  ia.besoin_humain || prev.demandeHandover || false,\n  step:           newStep,\n  leadData:       updatedConv\n}}];"
      },

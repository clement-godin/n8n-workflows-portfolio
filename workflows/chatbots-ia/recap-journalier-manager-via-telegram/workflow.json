      {
        "parameters": {
          "jsCode": "let notesCompilees = \"\";\nfor (const item of $input.all()) {\n  let heure = item.json.heure;\n  let texte = item.json['note transcript'];\n  notesCompilees += `- Note de ${heure} : ${texte}\\n`;\n}\nreturn [{ json: { prompt_data: notesCompilees } }];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [

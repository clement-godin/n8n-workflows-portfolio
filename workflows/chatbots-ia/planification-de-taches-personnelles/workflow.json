      {
        "parameters": {
          "jsCode": "let text = $json.text;\n\n// Nettoyage robuste caractère par caractère\nconst start = text.indexOf('{');\nconst end = text.lastIndexOf('}');\ntext = text.substring(start, end + 1);\n\nconst parsed = JSON.parse(text);\n\n// Construction du message de confirmation\n// On ajoute la ligne Heure avec une valeur par défaut\nconst confirmation = `✅ Voici ce que j'ai compris :\n\n📌 *Titre :* ${parsed.titre}\n📅 *Date :* ${parsed.date || 'Non précisée'}\n⏰ *Heure :* ${parsed.heure || 'Non précisée'}\n📝 *Description :* ${parsed.description || 'Aucune'}\n\nRéponds *OUI* pour confirmer ou *NON* pour annuler.`;\n\nreturn [{ json: { ...parsed, confirmation } }];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          704,
          200
        ],
        "id": "7d7e471c-c13b-48e1-b74d-ff3771c3da85",
        "name": "Code JS - Parse réponse LLM"
      },
      {
        "parameters": {
          "chatId": "={{ $('Trigger - Telegram tâches').item.json.callback_query.message.chat.id }}",
          "text": "=Ok, j'annule. Envoie-moi un nouveau vocal ou message !",

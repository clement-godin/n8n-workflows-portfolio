        ],
        "id": "6df124e4-0b8b-415b-a709-3bc77a593925",
        "name": "Send a text message3",
        "webhookId": "4488de6e-d295-4619-bbab-dfd73a2ecc74",
        "credentials": {
          "telegramApi": {
            "id": "QOeg5qJb6B6fLLB5",
            "name": "planification_taches_bot"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "// On cible spécifiquement le noeud \"Telegram Trigger\" pour récupérer le texte\nconst triggerData = $('Trigger - Telegram tâches').first().json;\nconst text = String(triggerData.callback_query?.message?.text || \"\");\n\n\nfunction extractCleanValue(keyword) {\n    const line = text.split('\\n').find(l => l.includes(keyword));\n    if (!line) return null;\n    const index = line.indexOf(':');\n    if (index === -1) return null;\n    let value = line.substring(index + 1);\n    value = value.replace(/[\\*📌📅⏰📝✅]/g, '').trim();\n    value = value.replace(/^,\\s*/, '').trim();\n    return value !== \"\" ? value : null;\n}\n\nconst titre       = extractCleanValue('Titre');\nconst dateStr     = extractCleanValue('Date');\nconst heureStr    = extractCleanValue('Heure');\nconst description = extractCleanValue('Description');\n\nlet clickUpTimestamp = null;\nlet hasTime = false;\n\nif (dateStr && dateStr !== 'Non précisée' && dateStr !== 'null') {\n\n    hasTime = !!(heureStr && heureStr !== 'Non précisée' && heureStr !== 'null');\n    const finalHeure = hasTime ? heureStr : \"00:00\";\n\n    // On crée la date brute (le serveur l'interprète dans son propre fuseau)\n    const rawDate = new Date(`${dateStr}T${finalHeure}:00`);\n\n    if (!isNaN(rawDate.getTime())) {\n        // Astuce infaillible : on force le calcul par rapport à l'heure de Paris\n        const dateInParisStr = rawDate.toLocaleString(\"en-US\", { timeZone: \"Europe/Paris\" });\n        const dateInParis = new Date(dateInParisStr);\n        \n        // On compense la différence exacte entre le serveur et Paris\n        const offset = rawDate.getTime() - dateInParis.getTime();\n        \n        // Le timestamp final est prêt pour ClickUp\n        clickUpTimestamp = rawDate.getTime() + offset;\n    }\n}\n\nconst finalDescription = (description && description !== 'Aucune' && description !== 'null')\n    ? description\n    : null;\n\nreturn [{\n    json: {\n        name: titre,\n        due_date: clickUpTimestamp,\n        due_date_time: hasTime, // L'excellente idée que vous avez eue !\n        description: finalDescription\n    }\n}];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          704,
          1088
        ],
        "id": "ac304161-528e-4564-907a-dfc637ead67a",
        "name": "Code JS - Prépare tâche ClickUp"
